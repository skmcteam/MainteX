# Database — update <your-pg-user> to match your local PostgreSQL username
DATABASE_URL="postgresql://<your-pg-user>@localhost:5432/skmc_cmms"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Application
NODE_ENV="development"

# Optional: Email notifications (Resend)
# RESEND_API_KEY=""

# Optional: LINE Notify
# LINE_NOTIFY_TOKEN=""
